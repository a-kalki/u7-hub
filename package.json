{
  "name": "u7-hub",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@happy-dom/global-registrator": "^18.0.1",
    "@playwright/test": "^1.55.1",
    "@types/bun": "latest",
    "@types/markdown-it": "^14.1.2",
    "dotenv-cli": "^10.0.0",
    "playwright": "^1.55.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "happy-dom": "^18.0.1",
    "markdown-it": "^14.1.1",
    "markdown-it-attrs": "^4.3.1",
    "markdown-it-bracketed-spans": "^1.0.1",
    "markdown-it-container": "^4.0.0"
  },
  "scripts": {
    "db:backup": "NODE_ENV=production bun run packages/core/src/db-utils/backup-db.ts",
    "db:backup:list": "bun run packages/core/src/db-utils/backup-db.ts --list",
    "db:backup:cleanup": "bun run packages/core/src/db-utils/backup-db.ts --cleanup",
    "db:backup:named": "bun run packages/core/src/db-utils/backup-db.ts --name=pre-migration",
    "db:migrate": "NODE_ENV=production bun run packages/core/src/db-utils/run-migrations.ts --force",
    "db:status": "NODE_ENV=production bun run packages/core/src/db-utils/run-migrations.ts --status",
    "metrics": "bun run packages/core/src/db-utils/view-events.ts",
    "metrics:watch": "bun run packages/core/src/db-utils/view-events.ts --watch",
    "dev:server": "NODE_ENV=development bun --hot run packages/core/src/server.ts",
    "build:dev": "NODE_ENV=development bun run build.ts --dev --watch",
    "start:dev": "bun run build:dev & bun run dev:server",
    "build:prod": "NODE_ENV=production bun run build.ts --prod",
    "start:prod": "bun run db:backup && bun run db:migrate && bun run build:prod && pm2 start ecosystem.config.cjs --env production",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui"
  }
}
