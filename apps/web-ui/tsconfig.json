{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun-types"],
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "outDir": "./dist-types",
    "rootDir": "./src"
  },
  "include": ["src/**/*.ts", "build.ts"],
  "exclude": ["node_modules", "dist-types", "dist"],
  "references": [
    { "path": "../../packages/core" },
    { "path": "../../packages/nur-course" },
    { "path": "../../packages/community" }
  ]
}
